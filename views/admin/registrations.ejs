<%- include('layout-top') %>
<div class="admin-content">
  <div class="admin-panel">
    <div class="panel-header"><h2>Event Registrations (<%= registrations.length %>)</h2></div>
    <% if (registrations.length === 0) { %>
      <p class="empty-msg">No registrations yet.</p>
    <% } else { %>
    <div class="table-wrap">
      <table class="admin-table admin-table-full">
        <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Event</th><th>Event Date</th><th>Dietary/Access</th><th>Registered</th></tr></thead>
        <tbody>
          <% registrations.forEach(r => { %>
          <tr>
            <td><strong><%= r.firstName %> <%= r.lastName %></strong></td>
            <td><a href="mailto:<%= r.email %>"><%= r.email %></a></td>
            <td><%= r.phone || '—' %></td>
            <td><%= r.eventTitle %></td>
            <td><%= new Date(r.eventDate).toLocaleDateString('en-SG') %></td>
            <td><%= r.dietaryNeeds || '—' %></td>
            <td><%= new Date(r.createdAt).toLocaleDateString('en-SG') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
<%- include('layout-bottom') %>
