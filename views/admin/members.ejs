<%- include('layout-top') %>

<div class="admin-content">
  <div class="admin-panel">
    <div class="panel-header">
      <h2>Community Members (<%= members.length %>)</h2>
    </div>

    <% if (members.length === 0) { %>
      <div class="empty-state-admin">
        <p>No members yet. Share the membership link: <a href="/membership">/membership</a></p>
      </div>
    <% } else { %>
    <div class="table-wrap">
      <table class="admin-table admin-table-full">
        <thead>
          <tr><th>Name</th><th>Email</th><th>Phone</th><th>Tier</th><th>Interests</th><th>Newsletter</th><th>Joined</th></tr>
        </thead>
        <tbody>
          <% members.forEach(m => { %>
          <tr>
            <td><strong><%= m.firstName %> <%= m.lastName %></strong></td>
            <td><a href="mailto:<%= m.email %>"><%= m.email %></a></td>
            <td><%= m.phone || '—' %></td>
            <td><span class="tier-tag tier-<%= m.memberType %>"><%= m.memberType %></span></td>
            <td>
              <div class="tag-wrap">
                <% (m.interests || []).forEach(i => { %><span class="tag tag-sm"><%= i %></span><% }) %>
              </div>
            </td>
            <td><%= m.newsletter ? '✓' : '—' %></td>
            <td><%= new Date(m.createdAt).toLocaleDateString('en-SG') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('layout-bottom') %>
