<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Roboto+Condensed:wght@700;900&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

<div class="admin-layout">
  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-logo">
      <span class="logo-fp">FP</span>
      <span>Admin</span>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-item <%= currentPath === '/admin' ? 'active' : '' %>">
        <span>📊</span> Dashboard
      </a>
      <a href="/admin/volunteers" class="admin-nav-item <%= currentPath === '/admin/volunteers' ? 'active' : '' %>">
        <span>🙋</span> Volunteers
      </a>
      <a href="/admin/members" class="admin-nav-item <%= currentPath === '/admin/members' ? 'active' : '' %>">
        <span>👥</span> Members
      </a>
      <a href="/admin/events" class="admin-nav-item <%= currentPath === '/admin/events' ? 'active' : '' %>">
        <span>📅</span> Events
      </a>
      <a href="/admin/registrations" class="admin-nav-item <%= currentPath === '/admin/registrations' ? 'active' : '' %>">
        <span>✅</span> Registrations
      </a>
      <a href="/admin/contacts" class="admin-nav-item <%= currentPath === '/admin/contacts' ? 'active' : '' %>">
        <span>📬</span> Messages
      </a>
    </nav>
    <div class="admin-sidebar-footer">
      <a href="/" target="_blank" class="admin-nav-item">🌿 View Site</a>
      <a href="/admin/logout" class="admin-nav-item admin-logout">⬅ Logout</a>
    </div>
  </aside>

  <!-- Main content -->
  <main class="admin-main">
    <div class="admin-topbar">
      <h1 class="admin-page-title"><%= title.split('—')[0].trim() %></h1>
      <div class="admin-topbar-right">
        <span class="admin-user">Fashion Parade Admin</span>
      </div>
    </div>
    <%- include('flash') %>
