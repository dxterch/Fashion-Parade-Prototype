<%- include('partials/head') %>
<%- include('partials/nav') %>

<section class="page-hero page-hero-pink">
  <div class="container">
    <div class="page-hero-content">
      <div class="section-eyebrow">Community</div>
      <h1>Our <em>People</em></h1>
      <p>Meet the collective — 70+ passionate Gen Z creatives, strategists, designers and advocates building a more conscious fashion future in Singapore.</p>
      <a href="/membership" class="btn-primary">Join the Community ✦</a>
    </div>
  </div>
</section>

<!-- Full-width photo banner -->
<div style="height:340px;overflow:hidden;position:relative;">
  <img src="/images/team-2.jpg" alt="Fashion Parade collective" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;">
  <div style="position:absolute;inset:0;background:linear-gradient(to right, rgba(255,1,153,0.35), rgba(39,33,253,0.35));"></div>
  <div style="position:absolute;bottom:2rem;left:2rem;color:white;">
    <div style="font-family:'Roboto Condensed',sans-serif;font-weight:900;font-size:clamp(2rem,5vw,3.5rem);text-transform:uppercase;letter-spacing:-1px;line-height:1;">Advocating for<br>Sustainable Fashion</div>
    <div style="font-family:'Quicksand',sans-serif;font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;opacity:0.85;margin-top:0.5rem;">★ A Gen Z Community ★ Singapore ★</div>
  </div>
</div>

<section class="community-section">
  <div class="container">

    <!-- Values -->
    <div class="community-values">
      <div class="section-eyebrow">Our Values</div>
      <h2 class="section-title">What We <em>Stand For</em></h2>
      <div class="values-grid">
        <div class="value-card">
          <span class="value-icon">🌱</span>
          <h3>Conscious Consumption</h3>
          <p>We challenge the fast fashion norm and encourage thoughtful, intentional choices about what we wear and how we buy.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">🤝</span>
          <h3>Radical Inclusivity</h3>
          <p>Sustainable fashion is for everyone. We welcome all backgrounds, styles and experience levels — no gatekeeping here.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">✨</span>
          <h3>Creative Innovation</h3>
          <p>We believe the most powerful sustainable fashion solutions come from bold, creative thinking — not just conventional approaches.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">📢</span>
          <h3>Gen Z Voice</h3>
          <p>Unapologetically Gen Z — speaking in our own voice, on our own terms, about issues that matter to our generation.</p>
        </div>
      </div>
    </div>

    <!-- Textile installations showcase -->
    <div style="margin-bottom:4rem;">
      <div class="section-eyebrow">Our Installations</div>
      <h2 class="section-title">Making Fashion <em>Visible</em></h2>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-top:1rem;">
        <div style="border-radius:var(--radius);overflow:hidden;height:260px;">
          <img src="/images/installation-mural-1.jpg" alt="Art of Everyone Mural" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        </div>
        <div style="border-radius:var(--radius);overflow:hidden;height:260px;">
          <img src="/images/installation-indo-sg-1.jpg" alt="INDO x SG Installation" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        </div>
        <div style="border-radius:var(--radius);overflow:hidden;height:260px;">
          <img src="/images/installation-marine-parade-2.jpg" alt="Marine Parade Installation" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
        </div>
      </div>
    </div>

    <!-- Podcast -->
    <div class="podcast-section">
      <div class="section-eyebrow">GEN Z Chats Podcast</div>
      <h2 class="section-title">Real Talk About <em>Fashion & Planet</em></h2>
      <div class="podcast-card">
        <div class="podcast-icon">🎙️</div>
        <div class="podcast-info">
          <h3>GEN Z Chats</h3>
          <p>Our podcast series where we get real about sustainable fashion — the good, the greenwashed and everything in between. New episodes regularly on Spotify and Apple Podcasts.</p>
          <div class="podcast-cta">
            <span class="tag" style="background:var(--lime);color:#333;">🎧 Spotify</span>
            <span class="tag" style="background:var(--sky);color:#333;">🎧 Apple Podcasts</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Partners -->
    <div style="margin-bottom:4rem;">
      <div class="section-eyebrow">Partners & Institutions</div>
      <h2 class="section-title">Working With <em>Singapore</em></h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;">
        <div style="border-radius:var(--radius);overflow:hidden;height:220px;position:relative;border:2px solid var(--bubblegum);">
          <img src="/images/partnership-nus-1.jpg" alt="NUS x Fashion Parade" style="width:100%;height:100%;object-fit:cover;">
          <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.7));padding:1.5rem 1rem 0.75rem;">
            <div style="font-family:'Roboto Condensed',sans-serif;font-weight:900;font-size:1.1rem;color:white;text-transform:uppercase;">NUS x Fashion Parade</div>
            <div style="font-family:'Quicksand',sans-serif;font-size:0.78rem;font-weight:700;color:rgba(255,255,255,0.8);text-transform:uppercase;letter-spacing:0.06em;">Educational Partnership</div>
          </div>
        </div>
        <div style="border-radius:var(--radius);overflow:hidden;height:220px;position:relative;border:2px solid var(--sky);">
          <img src="/images/partnership-nus-2.jpg" alt="NUS High x Fashion Parade" style="width:100%;height:100%;object-fit:cover;">
          <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.7));padding:1.5rem 1rem 0.75rem;">
            <div style="font-family:'Roboto Condensed',sans-serif;font-weight:900;font-size:1.1rem;color:white;text-transform:uppercase;">NUS High x Fashion Parade</div>
            <div style="font-family:'Quicksand',sans-serif;font-size:0.78rem;font-weight:700;color:rgba(255,255,255,0.8);text-transform:uppercase;letter-spacing:0.06em;">School Outreach</div>
          </div>
        </div>
      </div>
    </div>

    <div class="join-community-cta">
      <h2>Be Part of <em>Something Real</em></h2>
      <p>Our community is built on genuine passion, creative energy and real friendships. We'd love to have you.</p>
      <div class="hero-cta" style="justify-content:center;">
        <a href="/membership" class="btn-primary">Join for Free</a>
        <a href="/volunteer/apply" class="btn-secondary">Volunteer With Us</a>
      </div>
    </div>

  </div>
</section>

<%- include('partials/footer') %>
