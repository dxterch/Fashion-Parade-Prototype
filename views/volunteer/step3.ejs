<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="form-section">
  <div class="container container-sm">
    <div class="form-header">
      <a href="/volunteer/apply/step2" class="back-link">← Back to Step 2</a>
      <h1>Your Motivation</h1>
      <p>Tell us why sustainable fashion matters to you — almost done!</p>
    </div>

    <div class="progress-bar">
      <div class="progress-step done">
        <div class="progress-dot">✓</div>
        <span>About You</span>
      </div>
      <div class="progress-line active"></div>
      <div class="progress-step done">
        <div class="progress-dot">✓</div>
        <span>Skills</span>
      </div>
      <div class="progress-line active"></div>
      <div class="progress-step active">
        <div class="progress-dot">3</div>
        <span>Motivation</span>
      </div>
    </div>

    <form class="fp-form" action="/volunteer/apply/submit" method="POST">

      <div class="form-group">
        <label for="motivation">Why do you want to volunteer with Fashion Parade? *</label>
        <textarea id="motivation" name="motivation" required rows="4"
          placeholder="Tell us what drew you to sustainable fashion and what you hope to contribute to our community..."><%= formData.motivation || '' %></textarea>
        <span class="field-hint">Min. 50 characters</span>
      </div>

      <div class="form-group">
        <label for="sustainableFashionStatement">What does sustainable fashion mean to you? *</label>
        <textarea id="sustainableFashionStatement" name="sustainableFashionStatement" required rows="3"
          placeholder="In your own words — no right or wrong answer!"><%= formData.sustainableFashionStatement || '' %></textarea>
      </div>

      <div class="form-group">
        <label for="heardFrom">How did you hear about Fashion Parade?</label>
        <select id="heardFrom" name="heardFrom">
          <option value="">Select one</option>
          <option value="instagram">Instagram</option>
          <option value="tiktok">TikTok</option>
          <option value="facebook">Facebook</option>
          <option value="linkedin">LinkedIn</option>
          <option value="friend">Friend / Word of mouth</option>
          <option value="event">At an event</option>
          <option value="podcast">GEN Z Chats Podcast</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="form-group">
        <label class="checkbox-single">
          <input type="checkbox" name="agreeToTerms" required>
          <span>I agree to Fashion Parade's volunteer terms and understand this is a voluntary, unpaid role. I confirm the information above is accurate. *</span>
        </label>
      </div>

      <button type="submit" class="btn-primary btn-full">Submit Application ✦</button>
      <p class="apply-note" style="text-align:center;margin-top:1rem;">We'll get back to you within 5–7 working days.</p>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
