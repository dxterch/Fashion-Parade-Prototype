<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="form-section">
  <div class="container container-sm">
    <div class="form-header">
      <a href="/volunteer/apply" class="back-link">← Back to Step 1</a>
      <h1>Skills & Availability</h1>
      <p>Help us match you with the right role in our team.</p>
    </div>

    <div class="progress-bar">
      <div class="progress-step done">
        <div class="progress-dot">✓</div>
        <span>About You</span>
      </div>
      <div class="progress-line active"></div>
      <div class="progress-step active">
        <div class="progress-dot">2</div>
        <span>Skills</span>
      </div>
      <div class="progress-line"></div>
      <div class="progress-step">
        <div class="progress-dot">3</div>
        <span>Motivation</span>
      </div>
    </div>

    <form class="fp-form" action="/volunteer/apply/step2" method="POST">

      <div class="form-group">
        <label>Areas you're interested in * <span class="label-hint">(select all that apply)</span></label>
        <div style="background:var(--lime);border-radius:var(--radius-sm);padding:0.85rem 1rem;margin-bottom:0.75rem;font-family:'Quicksand',sans-serif;font-size:0.82rem;font-weight:700;color:#5a4a00;">
          🎯 <strong>Grants Taskforce roles available!</strong> If you have skills in Grant Writing, Impact Data Tracking, Financial Administration or Corporate Outreach — we especially need you. These roles directly reduce admin burden on our core team.
        </div>
        <div class="checkbox-grid">
          <% const skillOptions = ['Content Creation', 'Events Planning', 'Social Media', 'Photography/Videography', 'Graphic Design', 'Partnerships & Outreach', 'Research & Strategy', 'Community Management', 'Fashion Styling', 'Upcycling/Crafts', 'Writing/Copywriting', 'Web/Tech', 'Grant Writing', 'Impact Data Tracking', 'Financial Administration', 'Corporate Outreach / CSR'] %>
          <% skillOptions.forEach(skill => { %>
          <label class="checkbox-card">
            <input type="checkbox" name="skills" value="<%= skill %>"
              <%= (formData.skills && formData.skills.includes(skill)) ? 'checked' : '' %>>
            <span><%= skill %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Availability * <span class="label-hint">(select all that apply)</span></label>
        <div class="checkbox-grid checkbox-grid-sm">
          <% const avail = ['Weekday Mornings', 'Weekday Afternoons', 'Weekday Evenings', 'Weekend Mornings', 'Weekend Afternoons', 'Weekend Evenings'] %>
          <% avail.forEach(a => { %>
          <label class="checkbox-card">
            <input type="checkbox" name="availability" value="<%= a %>"
              <%= (formData.availability && formData.availability.includes(a)) ? 'checked' : '' %>>
            <span><%= a %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="hoursPerMonth">Hours available per month *</label>
          <select id="hoursPerMonth" name="hoursPerMonth" required>
            <option value="">Select range</option>
            <option value="1-5" <%= formData.hoursPerMonth === '1-5' ? 'selected' : '' %>>1–5 hours</option>
            <option value="5-10" <%= formData.hoursPerMonth === '5-10' ? 'selected' : '' %>>5–10 hours</option>
            <option value="10-20" <%= formData.hoursPerMonth === '10-20' ? 'selected' : '' %>>10–20 hours</option>
            <option value="20+" <%= formData.hoursPerMonth === '20+' ? 'selected' : '' %>>20+ hours</option>
          </select>
        </div>
        <div class="form-group">
          <label for="experience">Relevant experience level</label>
          <select id="experience" name="experience">
            <option value="none" <%= formData.experience === 'none' ? 'selected' : '' %>>No experience — eager to learn!</option>
            <option value="some" <%= formData.experience === 'some' ? 'selected' : '' %>>Some experience (hobbyist / school projects)</option>
            <option value="professional" <%= formData.experience === 'professional' ? 'selected' : '' %>>Professional experience</option>
          </select>
        </div>
      </div>

      <button type="submit" class="btn-primary btn-full">Continue to Step 3 →</button>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
