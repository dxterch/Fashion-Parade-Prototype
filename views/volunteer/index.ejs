<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<section class="page-hero page-hero-lime">
  <div class="container">
    <div class="page-hero-content">
      <div class="section-eyebrow">Work With Us</div>
      <h1>Volunteer With<br><em>Fashion Parade</em></h1>
      <p>Be part of a passionate Gen Z collective driving the sustainable fashion movement in Singapore. No experience needed — just genuine enthusiasm!</p>
      <a href="/volunteer/apply" class="btn-primary">Start Application ✦</a>
    </div>
  </div>
</section>

<!-- Workshop photo strip -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);height:220px;overflow:hidden;">
  <div style="overflow:hidden;"><img src="/images/workshop-sewing-2.jpg" alt="" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"></div>
  <div style="overflow:hidden;"><img src="/images/workshop-natural-dye-3.jpg" alt="" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"></div>
  <div style="overflow:hidden;"><img src="/images/workshop-textile-portraits-2.jpg" alt="" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"></div>
  <div style="overflow:hidden;"><img src="/images/installation-mural-3.jpg" alt="" style="width:100%;height:100%;object-fit:cover;transition:transform .5s ease;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform='scale(1)'"></div>
</div>

<section class="roles-section">
  <div class="container">
    <div class="section-eyebrow">What You'll Do</div>
    <h2 class="section-title">Find Your <em>Role</em></h2>
    <div class="roles-grid">
      <div class="role-card">
        <span class="role-icon">✍️</span>
        <h3>Content Creator</h3>
        <p>Write, film, and design content across Instagram, TikTok and our blog. Help tell our story to the world.</p>
      </div>
      <div class="role-card">
        <span class="role-icon">📅</span>
        <h3>Events Coordinator</h3>
        <p>Plan, organise and execute our workshops, markets and showcases. Bring people together around fashion.</p>
      </div>
      <div class="role-card">
        <span class="role-icon">🤝</span>
        <h3>Partnerships & Outreach</h3>
        <p>Connect with brands, schools and organisations. Build relationships that amplify our message.</p>
      </div>
      <div class="role-card">
        <span class="role-icon">🎨</span>
        <h3>Creative & Design</h3>
        <p>Shape the visual identity of Fashion Parade — from graphics to physical displays and workshop materials.</p>
      </div>
      <div class="role-card">
        <span class="role-icon">💬</span>
        <h3>Community Manager</h3>
        <p>Grow and nurture our online and offline community. Respond to DMs, moderate discussions and welcome new members.</p>
      </div>
      <div class="role-card">
        <span class="role-icon">📊</span>
        <h3>Research & Strategy</h3>
        <p>Analyse trends, track impact and help guide our roadmap. Turn data into actionable insights for the team.</p>
      </div>
    </div>
    <div class="apply-cta">
      <a href="/volunteer/apply" class="btn-primary btn-lg">Apply to Volunteer →</a>
      <p class="apply-note">Applications reviewed within 5–7 working days</p>
    </div>
  </div>
</section>

<section class="process-section">
  <div class="container">
    <div class="section-eyebrow" style="border-color:var(--lime);color:var(--lime);">How It Works</div>
    <h2 class="section-title" style="color:var(--white);">The <em>Onboarding</em> Journey</h2>
    <div class="steps-row">
      <div class="step">
        <div class="step-num">01</div>
        <h4>Apply Online</h4>
        <p>Fill out our 3-step application — takes about 5 minutes.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">02</div>
        <h4>Review & Matching</h4>
        <p>We review your skills and match you to the best role.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">03</div>
        <h4>Onboarding Call</h4>
        <p>A short call with the team to welcome you in.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step">
        <div class="step-num">04</div>
        <h4>Get Started!</h4>
        <p>Join Slack, attend your first session, start making impact.</p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
